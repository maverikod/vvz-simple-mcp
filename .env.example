# Публичный origin без конечного слэша (HTTPS в проде). Для OAuth обязателен тот же хост, что у коннектора.
PUBLIC_BASE_URL=https://example.com

# Google OAuth (если заданы оба — включается защита MCP + метаданные для ChatGPT)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Стабильная подпись JWT между рестартами (рекомендуется в проде)
# JWT_SIGNING_KEY=

# При старте вывести в лог политику scope (required / valid / securitySchemes инструментов)
# AUTH_LOG_SCOPES=1
