# Public origin — MUST be HTTPS in production (OpenAI / ChatGPT). No trailing slash.
# Example production (HTTPS):
PUBLIC_BASE_URL=https://mcp.techsup.od.ua

# Google OAuth (required for ChatGPT / OpenAI connector OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local dev only — HTTP is OK for localhost; use HTTPS above for real deployment.
# PUBLIC_BASE_URL=http://127.0.0.1:8000
